@main @def ymir = bare-metal {
	name: 'ymir',
	root: 'ymir.rs',
	language: 'rust',
	linker_script: 'ymir.ld',
	dependencies: [
		::libs::ogma::lib,
		::libs::apis::lib,
		::libs::oshun::lib,
		::libs::macro-rules-attr::macro,
	],
	panic: 'abort',
}

dummy-kernel = kernel {
	name: 'dummy',
	language: 'rust',
	root: 'dummy-kernel/main.rs',
	linker_script: 'dummy-kernel/linker.ld',
	panic: 'abort',
}
