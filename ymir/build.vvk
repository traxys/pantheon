@main @def ymir = bare-metal {
	name: 'ymir',
	root: 'ymir.rs',
	language: 'rust',
	linker_script: 'ymir.ld',
	dependencies: [::ogma::lib, ::apis::lib, ::oshun::lib, ::macro-rules-attr::macro],
	panic: 'abort',
}

dummy-kernel = kernel {
	name: 'dummy',
	language: 'rust',
	root: 'dummy-kernel/main.rs',
	linker_script: 'dummy-kernel/linker.ld',
	panic: 'abort',
}
