@def core = library {
	name: 'wohpe',
	language: 'rust',
	root: 'core.rs',
	dependencies: [::libs::oshun::lib],
}

@def env = library {
	name: 'wohpe_env',
	language: 'rust',
	root: 'env.rs',
	dependencies: [core],
}

@def qemu = library {
	name: 'wohpe_qemu',
	language: 'rust',
	root: 'qemu.rs',
	dependencies: [core, ::libs::oshun::lib],
}

test {
	file: 'core_test.rs',
	for: core,
	dependencies: [::libs::oshun::lib],
	parallel: false,
}
